# ===== Server =====
PORT=5000
NODE_ENV=development

# JWT secret untuk sign token login
JWT_SECRET=ganti_dengan_secret_acak_panjang
JWT_EXPIRES_IN=7d

# ===== Database MySQL =====
# Untuk LOKAL isi variabel di bawah ini:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=utsmart

# Untuk RAILWAY: cukup pakai connection string yang otomatis disediakan Railway.
# Railway MySQL plugin menyediakan variabel MYSQL_URL (atau MYSQLHOST/MYSQLUSER/dst).
# Jika MYSQL_URL ada, kode akan otomatis memakainya dan mengabaikan DB_* di atas.
# MYSQL_URL=mysql://user:password@host:port/railway

# ===== Admin default (di-seed otomatis) =====
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@utsmart.com
ADMIN_PASSWORD=admin123

# ===== WhatsApp Checkout (click-to-chat) =====
# Setelah checkout, customer diarahkan chat ke WA owner dengan pesan order otomatis.
# Isi nomor WA owner (format internasional tanpa +, mis. 6281234567890)
OWNER_WA_NUMBER=

# ===== Upload Gambar =====
# Folder penyimpanan file upload. Di Railway, arahkan ke mount path volume
# persisten (mis. /app/uploads) lewat Variables agar gambar tidak hilang saat redeploy.
# Kosongkan untuk pakai default lokal (./uploads).
UPLOAD_DIR=

# ===== CORS =====
# Daftar origin frontend yang diizinkan, pisahkan koma. Kosongkan untuk izinkan semua (*).
CORS_ORIGIN=
